APP_NAME="Mini Car Rental API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=mini_car_rental
DB_USERNAME=postgres
DB_PASSWORD=password

CACHE_STORE=redis
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

RATE_LIMITING_ENABLED=true
