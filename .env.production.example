APP_NAME="Mini Car Rental"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://127.0.0.1

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=mini_car_rental
DB_USERNAME=postgres
DB_PASSWORD=change-me-db-password

CACHE_STORE=redis
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

RATE_LIMITING_ENABLED=true

BROADCAST_CONNECTION=reverb

# Placeholders — replace before deploy. Do not commit real secrets.
REVERB_APP_ID=changeme-reverb-id
REVERB_APP_KEY=changeme-reverb-key
REVERB_APP_SECRET=changeme-reverb-secret

# Laravel app → Reverb container (Docker DNS)
REVERB_HOST=reverb
REVERB_PORT=8081
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8081

# Browser / Vite build-time args (used by docker compose build)
# Same-origin through Nginx on port 80
VITE_API_BASE_URL=/api
VITE_REVERB_APP_KEY=changeme-reverb-key
VITE_REVERB_HOST=127.0.0.1
VITE_REVERB_PORT=80
VITE_REVERB_SCHEME=http

# Postgres image bootstrap (compose maps these)
POSTGRES_DB=mini_car_rental
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-db-password
